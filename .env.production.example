# Intentionally invalid template: replace every placeholder, then split it into
# root-only api.env, worker.env, database.env and operations.env before startup.
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
PUBLIC_ORIGIN=https://orosaga.wanhuchangan.com
DATABASE_URL=postgresql://USER:PASSWORD@RDS_HOST:5432/yishan_verse?schema=orosaga&sslmode=disable
DATABASE_ALLOW_PLAINTEXT_INTERNAL=true
SESSION_SECRET=GENERATE_AT_LEAST_32_RANDOM_CHARACTERS

FEISHU_APP_ID=SET_ON_SERVER
FEISHU_APP_SECRET=SET_ON_SERVER
FEISHU_REDIRECT_URI=https://orosaga.wanhuchangan.com/auth/feishu/callback
FEISHU_API_BASE_URL=https://open.feishu.cn
FEISHU_WIKI_HOST=wanhuxian.feishu.cn
FEISHU_WIKI_ROOT_NODE_TOKEN=SET_ON_SERVER
FEISHU_WIKI_EXCLUDED_TITLES=SET_ON_SERVER
FEISHU_WIKI_SOURCE_NAME=飞书个人分享营地

OSS_REGION=oss-cn-beijing
OSS_ENDPOINT=oss-cn-beijing-internal.aliyuncs.com
OSS_BUCKET=orosaga
OSS_ACCESS_KEY_ID=SET_ON_SERVER
OSS_ACCESS_KEY_SECRET=SET_ON_SERVER

SYSTEM_LINK_ALLOWED_HOSTS=wanhuchangan.com,good.wanhuchangan.cn,noah.wanhuchangan.com,dash.wanhuchangan.cn,status.geokeji.com
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast?latitude=34.3416&longitude=108.9398&current=temperature_2m,weather_code&timezone=Asia%2FShanghai
SYNC_INTERVAL_MINUTES=30
AUTH_DEV_BYPASS=false
OROSAGA_INITIAL_ADMIN_NAMES=SET_ON_SERVER
