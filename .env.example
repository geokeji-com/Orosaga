NODE_ENV=development
PORT=3000
HOST=0.0.0.0
DATABASE_URL=postgresql://orosaga:orosaga@postgres:5432/orosaga?schema=orosaga
DATABASE_ALLOW_PLAINTEXT_INTERNAL=false
PUBLIC_ORIGIN=http://localhost:8080
SESSION_SECRET=replace-with-at-least-32-random-characters
FEISHU_APP_ID=cli_replace_me
FEISHU_APP_SECRET=load-from-kms-not-from-git
FEISHU_REDIRECT_URI=http://localhost:8080/auth/feishu/callback
FEISHU_API_BASE_URL=https://open.feishu.cn
FEISHU_WIKI_HOST=replace-with-tenant.feishu.cn
FEISHU_WIKI_ROOT_NODE_TOKEN=replace-with-root-node-token
FEISHU_WIKI_EXCLUDED_TITLES=replace-with-comma-separated-titles
FEISHU_WIKI_SOURCE_NAME=飞书知识营地
# Production only; inject these from KMS instead of committing values.
# OSS_REGION=oss-cn-hangzhou
# OSS_ENDPOINT=oss-cn-hangzhou-internal.aliyuncs.com
# OSS_UPLOAD_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_BUCKET=replace-with-private-bucket
# OSS_ACCESS_KEY_ID=load-from-kms-not-from-git
# OSS_ACCESS_KEY_SECRET=load-from-kms-not-from-git
# OSS_STS_TOKEN=load-short-lived-token-when-using-sts
SYSTEM_LINK_ALLOWED_HOSTS=example.com
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast?latitude=34.3416&longitude=108.9398&current=temperature_2m,weather_code&timezone=Asia%2FShanghai
SYNC_INTERVAL_MINUTES=30
AUTH_DEV_BYPASS=true
PRIVATE_ASSET_ROOT=/secure/orosaga-migration-assets
# OROSAGA_INITIAL_ADMIN_NAMES=replace-with-comma-separated-names
